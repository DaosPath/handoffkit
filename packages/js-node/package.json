{
  "name": "@handoffkit/node",
  "version": "1.8.9",
  "description": "Node.js filesystem utilities for HandoffKit traces, reports, and project context.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaosPath/handoffkit.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "license": "MIT",
  "scripts": {
    "check": "node --check src/index.js && node --check test/node.test.js",
    "test": "node --test"
  },
  "dependencies": {
    "@handoffkit/core": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
