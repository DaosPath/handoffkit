{
  "name": "@handoffkit/core",
  "version": "1.14.2",
  "description": "Browser-safe JavaScript contract layer for multi-agent workflows with structured handoffs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaosPath/handoffkit.git",
    "directory": "packages/js/core"
  },
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "!src/index.monolith.js",
    "!src/split.mjs",
    "README.md"
  ],
  "license": "MIT",
  "scripts": {
    "check": "node ../../../scripts/js/check-package.mjs",
    "test": "node --test",
    "prepack": "pnpm run check && pnpm run test"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/DaosPath/handoffkit#readme",
  "bugs": {
    "url": "https://github.com/DaosPath/handoffkit/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "handoff",
    "orchestration",
    "multi-agent",
    "llm",
    "browser",
    "contracts",
    "runtime"
  ],
  "sideEffects": false
}
