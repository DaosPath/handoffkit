{
  "name": "@handoffkit/cli",
  "version": "1.14.1",
  "description": "Autonomous Node.js CLI and offline demos for HandoffKit.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaosPath/handoffkit.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "bin": {
    "handoffkit-js": "./src/bin.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "check": "node --check src/index.js && node --check src/bin.js && node --check test/cli.test.js",
    "test": "node --test"
  },
  "dependencies": {
    "@handoffkit/core": "workspace:*",
    "@handoffkit/node": "workspace:*",
    "@handoffkit/recipes": "workspace:*",
    "@handoffkit/templates": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
