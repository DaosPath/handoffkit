{
  "name": "@handoffkit/cli",
  "version": "1.14.2",
  "description": "Autonomous Node.js CLI and offline demos for HandoffKit.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaosPath/handoffkit.git",
    "directory": "packages/js/cli"
  },
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "bin": {
    "handoffkit-js": "./src/bin.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "license": "MIT",
  "scripts": {
    "check": "node ../../../scripts/js/check-package.mjs",
    "test": "node --test",
    "prepack": "pnpm run check && pnpm run test"
  },
  "dependencies": {
    "@handoffkit/core": "workspace:*",
    "@handoffkit/node": "workspace:*",
    "@handoffkit/recipes": "workspace:*",
    "@handoffkit/templates": "workspace:*",
    "@handoffkit/providers": "workspace:*"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/DaosPath/handoffkit#readme",
  "bugs": {
    "url": "https://github.com/DaosPath/handoffkit/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "handoff",
    "orchestration",
    "multi-agent",
    "llm",
    "cli",
    "command-line",
    "developer-tools"
  ],
  "sideEffects": false
}
