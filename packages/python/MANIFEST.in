include README.md
include LICENSE
include LAYOUT.md
# Long-form docs are centralized under ../../docs/python and are repository-only.
graft examples
graft scripts
graft tests
prune examples/output
prune tests/_tmp_tool_execution
prune tests/_tmp_memory_context
# Local CLI output (not shipped); golden reports are under examples/fixtures/reports/
prune reports
prune runs
global-exclude __pycache__
global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.pyc.*
