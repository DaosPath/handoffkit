include README.md
include LICENSE
graft docs
graft examples
graft reports
graft scripts
graft tests
prune examples/output
prune tests/_tmp_tool_execution
prune tests/_tmp_memory_context
exclude reports/opencode_*
exclude reports/nvidia_*
exclude reports/groq_*
exclude reports/*partial.json
exclude reports/*runner_*.log
global-exclude __pycache__
global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.pyc.*
